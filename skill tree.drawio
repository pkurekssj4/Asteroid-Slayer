        <mxCell id="5pHtXvfLM7ZHYuY94Opz-11" value="&lt;span style=&quot;text-wrap: nowrap;&quot;&gt;Desperate Measures&lt;/span&gt;&lt;br style=&quot;padding: 0px; margin: 0px; text-wrap: nowrap;&quot;&gt;&lt;span style=&quot;text-wrap: nowrap;&quot;&gt;+15% base reload time&lt;/span&gt;&lt;br style=&quot;padding: 0px; margin: 0px; text-wrap: nowrap;&quot;&gt;&lt;span style=&quot;text-wrap: nowrap;&quot;&gt;+5% base rof&lt;/span&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1ba1e2;fontColor=#FFFFFF;strokeColor=#000000;fontSize=7;" parent="1" vertex="1">
