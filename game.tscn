[sub_resource type="Shader" id="Shader_vyqle"]
code = "shader_type canvas_item;

uniform float amplitude_x = 100.0;
uniform float frequency_x = 20.0;
uniform float speed_x = 0.1;

uniform float amplitude_y = 20.0;
uniform float frequency_y = 10.0;
uniform float speed_y = 0.2;

uniform float phase = 0.0;

void fragment() {
    float wave_x = sin(UV.y * frequency_x + phase * speed_x) * amplitude_x * TEXTURE_PIXEL_SIZE.x;
    float wave_y = cos(UV.x * frequency_y + phase * speed_y) * amplitude_y * TEXTURE_PIXEL_SIZE.y;

    vec2 uv = UV + vec2(wave_x, wave_y);
    COLOR = texture(TEXTURE, uv);
    COLOR.a *= 0.5; // ← przezroczystość 30%
}"

